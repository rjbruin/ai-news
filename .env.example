# ───────────────────────── AI News configuration ─────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production
PORT=5090
# SQLite by default (relative paths land in the Flask instance/ dir);
# set a Postgres URL like postgresql+psycopg://user:pass@host/db to switch.
DATABASE_URL=sqlite:///ainews.db

# --- Admins (comma-separated emails) ---
ADMIN_EMAILS=you@example.com

# --- LLM (global OpenRouter key, used for all analysis) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Tagging ---
# nb_only | nb_then_llm | llm_only
TAGGING_MODE=nb_then_llm
NB_CONFIDENCE_THRESHOLD=0.35

# --- TTS (ElevenLabs, for podcast summaries) ---
# Single global key shared by all podcast generation; voice/model config is
# set from the Admin page (Admin Settings), not env vars.
ELEVENLABS_API_KEY=

# --- Outgoing mail (SMTP, for magic links & verification) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=ainewsrjbruintjes@gmail.com
SMTP_PASSWORD=
MAIL_FROM=AI News <ainewsrjbruintjes@gmail.com>

# --- Newsletter mailbox (IMAP, for the imap_newsletter source) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=ainewsrjbruintjes@gmail.com
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
# Same mailbox's SMTP host/port, for sending edition-recipient confirmation
# mail from that address. Defaults to imap.<domain> -> smtp.<domain>; set
# explicitly if your provider doesn't follow that convention.
IMAP_SMTP_HOST=smtp.gmail.com
IMAP_SMTP_PORT=587

# --- Scheduler ---
# Default polling interval for sources, in seconds (3600 = 1 hour).
POLL_INTERVAL=3600
# Enable the background scheduler in this process (set false on web-only nodes).
WORKER_ENABLED=true

# --- App ---
PUBLIC_URL=https://ainews.rjbruintjes.nl

# --- Agentic summaries ---
# The agentic pipeline runs on each user's own OpenRouter key (set in Settings).
AGENT_ENABLED=true
# Max tool-calling steps per edition, and an optional token cap (0 = no cap).
AGENT_MAX_STEPS=24
AGENT_MAX_TOKENS=0
# How long to keep per-edition HEADLINES notes (dedup memory), in days.
AGENT_HEADLINES_RETENTION_DAYS=7
# Independent secret for encrypting stored per-user API keys (defaults to SECRET_KEY).
FERNET_SECRET=

# --- Lemon Squeezy (prepaid balance top-ups) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Local debug mode ---
# Set true to auto-populate the DB with fixture news items and force-cut summary
# editions at startup — no email or LLM credentials needed.
# Alternatively set FLASK_CONFIG=app.config.DebugConfig.
DEBUG_SEED=false
